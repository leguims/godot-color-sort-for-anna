; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Range les couleurs pour Anna mon amour"
config/description="Jeu de tri de jeton de couleurs pour Anna mon amour."
run/main_scene="res://Scenes/MenuPrincipal/menu_principal.tscn"
config/features=PackedStringArray("4.3", "GL Compatibility")
boot_splash/fullsize=false
config/icon="res://icon_128x128.svg"
config/windows_native_icon="res://icon.ico"

[autoload]

SauvegardeConfiguration="*res://Scenes/Sauvegarde/configuration.gd"
SauvegardeBddPlateaux="*res://Scenes/Sauvegarde/bdd_plateaux.gd"
SauvegardeListeJoueurs="*res://Scenes/Sauvegarde/liste_joueurs.gd"
SauvegardeBddJoueurs="*res://Scenes/Sauvegarde/bdd_joueurs.gd"
SauvegardeScores="*res://Scenes/Sauvegarde/scores.gd"

[display]

window/size/viewport_width=480
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/handheld/orientation=1

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_etc2_astc=true
